generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model News {
  id        Int      @id @default(autoincrement())
  title     String
  content   String
  imageUrl  String
  createdAt DateTime @default(now())
}

model Gallery {
  id       Int    @id @default(autoincrement())
  imageUrl String
}

model ContactMessage {
  id      Int    @id @default(autoincrement())
  name    String
  email   String
  message String
}